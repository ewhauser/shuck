#!/bin/sh
# shellcheck disable=2034
first() { echo $1; }
rest() { printf "%s\n" "$@"; }
conditional() { ${1+"$@"}; }
alias foo=$BAR
alias bar='$(printf hi)'
alias baz='noglob gtl'
alias func='helper() { echo hi; }'

