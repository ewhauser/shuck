#!/bin/bash
alias home='$HOME'
alias icloud='cd '\''$HOME'\'''
alias printf='$(command -v printf)'
alias math='$((1+2))'
alias list='${arr[@]}'
alias proc='<(printf hi)'
alias brace='{a,b}'
alias plain=printf
alias literal='$(command -v printf)'
alias param='${HOME}'
alias brace_lit='{a,b}'

