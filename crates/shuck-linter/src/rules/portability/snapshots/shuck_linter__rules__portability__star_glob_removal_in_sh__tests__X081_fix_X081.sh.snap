#!/bin/sh

# Should trigger: pattern trimming on $*
_shuck_positional_params=$*
echo "${_shuck_positional_params%%dBm*}"
_shuck_positional_params=$*
echo "${_shuck_positional_params%dBm*}"
_shuck_positional_params=$*
