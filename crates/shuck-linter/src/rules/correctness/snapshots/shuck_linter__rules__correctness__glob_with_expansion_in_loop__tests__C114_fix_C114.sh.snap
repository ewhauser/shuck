#!/bin/sh
for i in "$CWD"/file.*pattern*; do :; done
for i in "${CWD}"/file.*pattern*; do :; done
for i in "$(pwd)"/file.*pattern*; do :; done

for i in "$CWD"/file.*pattern*; do :; done
for i in file.*pattern*; do :; done
for i in "$CWD"/*.txt; do :; done
for i in "$DIR"/{1..3}*.txt; do :; done
